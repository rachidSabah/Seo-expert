// ─── Report Card ──────────────────────────────────────────────────────────────

interface ReportCardProps {
  analysis: SiteAnalysis & { siteName: string; domain: string };
  onViewReport: (a: SiteAnalysis & { siteName: string; domain: string }) => void;
  onDownloadCsv: (a: SiteAnalysis & { siteName: string; domain: string }, includeAi?: boolean) => void;
  onDownloadPdf: (a: SiteAnalysis & { siteName: string; domain: string }, includeAi?: boolean) => void;
}

function ReportCard({ analysis, onViewReport, onDownloadCsv, onDownloadPdf }: ReportCardProps) {
