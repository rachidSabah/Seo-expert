            <FileText className="h-4 w-4" />
            Download PDF
          </Button>
        </div>
      </DialogContent>
    </Dialog>
  );
}

// ─── Main Component ───────────────────────────────────────────────────────────

export function Reports() {
  const [analyses, setAnalyses] = useState<(SiteAnalysis & { siteName: string; domain: string })[]>([]);
  const [hydrated, setHydrated] = useState(false);
  const [viewReport, setViewReport] = useState<(SiteAnalysis & { siteName: string; domain: string }) | null>(null);
  const { toast } = useToast();
  const setCurrentPage = useAppStore((s) => s.setCurrentPage);

  // ── Load data on mount ──
  useEffect(() => {
    const loadData = () => {
      try {
        const data = getAllLatestAnalyses();
        setAnalyses(data);
      } catch {
        // localStorage not available
      }
      setHydrated(true);
    };

    loadData();

    const handleStorage = () => loadData();
    window.addEventListener("storage", handleStorage);
    const interval = setInterval(loadData, 3000);

    return () => {
      window.removeEventListener("storage", handleStorage);
      clearInterval(interval);
    };
  }, []);

  // ── Download handlers ──
  const handleDownloadCsv = useCallback(async (analysis: SiteAnalysis & { siteName: string; domain: string }, includeAi?: boolean) => {
    try {
      const result = buildSiteAnalysisResult(analysis);
      let csv = generateCsvReport(result);

      if (includeAi) {
        const issueTitles = analysis.issues.map(i => `${i.title} (${i.severity})`);
        const recs = await generateSeoRecommendations(analysis.url, analysis.score, issueTitles);
        if (recs) {
          csv += "\n\n--- AI SEO Recommendations ---\n";
          csv += "Category,Recommendation\n";
          csv += recs.priorityActions.map(a => `"Priority Action","${a}"`).join("\n") + "\n";
          csv += recs.contentIdeas.map(a => `"Content Idea","${a}"`).join("\n") + "\n";
          csv += recs.technicalFixes.map(a => `"Technical Fix","${a}"`).join("\n") + "\n";
        }
      }

      const domain = analysis.domain || "site";
      downloadFile(csv, `seo-report-${domain}-${Date.now()}.csv`, "text/csv");
      toast({ title: "CSV downloaded", description: `Report for ${domain} exported successfully.` });
    } catch {
      toast({ title: "Download failed", description: "Could not generate CSV report.", variant: "destructive" });
    }
  }, [toast]);

  const handleDownloadPdf = useCallback(async (analysis: SiteAnalysis & { siteName: string; domain: string }, includeAi?: boolean) => {
    try {
      const result = buildSiteAnalysisResult(analysis);
      let html = generateHtmlReport(result, analysis.siteName || analysis.domain);

      if (includeAi) {
        const issueTitles = analysis.issues.map(i => `${i.title} (${i.severity})`);
        const recs = await generateSeoRecommendations(analysis.url, analysis.score, issueTitles);
        if (recs) {
          const aiSection = `
          <div class="section">
            <h2>&#129302; AI-Powered Recommendations</h2>
            <h3 style="color:#dc2626">Priority Actions</h3>
            <ul class="suggestions-list">${recs.priorityActions.map(a => `<li>${a}</li>`).join("")}</ul>
            <h3 style="color:#d97706">Content Ideas</h3>
            <ul class="suggestions-list">${recs.contentIdeas.map(a => `<li>${a}</li>`).join("")}</ul>
            <h3 style="color:#0284c7">Technical Fixes</h3>
            <ul class="suggestions-list">${recs.technicalFixes.map(a => `<li>${a}</li>`).join("")}</ul>
          </div>`;
          html = html.replace('</div>\n  </body>', aiSection + '</div>\n  </body>');
        }
      }

      const domain = analysis.domain || "site";
      downloadFile(html, `seo-report-${domain}-${Date.now()}.html`, "text/html");
      toast({ title: "PDF report downloaded", description: `HTML report for ${domain} saved. Open in browser and print to PDF.` });
    } catch {
      toast({ title: "Download failed", description: "Could not generate HTML report.", variant: "destructive" });
    }
  }, [toast]);

  const handleExportAll = useCallback(() => {
    try {
      if (analyses.length === 0) return;
      const allCsv = analyses.map((a) => {
        const result = buildSiteAnalysisResult(a);
        return generateCsvReport(result);
      }).join("\n\n---\n\n");

      downloadFile(allCsv, `seo-reports-all-${Date.now()}.csv`, "text/csv");
      toast({ title: "All reports exported", description: `${analyses.length} report(s) exported as CSV.` });
    } catch {
      toast({ title: "Export failed", description: "Could not export reports.", variant: "destructive" });
    }
  }, [analyses, toast]);

  // ── Competitor CSV Export ──
  const handleExportCompetitorReport = useCallback(() => {
    try {
      const allCompetitorsStr = localStorage.getItem('seo_competitors');
      if (!allCompetitorsStr) {
        toast({ title: "No competitor data", description: "No competitor analyses found. Add competitors in the Competitor Analysis page.", variant: "destructive" });
        return;
      }

      const allCompetitors = JSON.parse(allCompetitorsStr) as Record<string, { id: string; url: string; domain: string; seoScore: number | null; lastAnalysisAt: string | null }[]>;
      const lines: string[] = [];

      lines.push("Competitor,Domain,SEO Score,Last Analyzed,Status");
      lines.push("");

      for (const [, competitors] of Object.entries(allCompetitors)) {
        for (const c of competitors) {
          const score = c.seoScore ?? 0;
          const status = score >= 80 ? "Good" : score >= 50 ? "OK" : "Poor";
          const lastAnalyzed = c.lastAnalysisAt ? new Date(c.lastAnalysisAt).toLocaleDateString() : "Never";
          lines.push(`"${c.domain}","${c.url}",${score},"${lastAnalyzed}","${status}"`);
        }
      }

      lines.push("");
      lines.push(`Exported: ${new Date().toISOString()}`);

      downloadFile(lines.join("\n"), `competitor-report-${Date.now()}.csv`, "text/csv");
      toast({ title: "Competitor report exported", description: "CSV with side-by-side competitor metrics downloaded." });
    } catch {
      toast({ title: "Export failed", description: "Could not export competitor report.", variant: "destructive" });
    }
  }, [toast]);

  // ── Schedule toggle/remove ──
  const [schedules, setSchedules] = React.useState<ReturnType<typeof getSchedules>>([]);

  const refreshSchedules = useCallback(() => {
    try { setSchedules(getSchedules()); } catch { /* noop */ }
  }, []);

  useEffect(() => {
    refreshSchedules();
    const handleStorage = () => refreshSchedules();
    window.addEventListener("storage", handleStorage);
    return () => window.removeEventListener("storage", handleStorage);
  }, [refreshSchedules]);

  const handleToggleSchedule = useCallback((id: string) => {
    try { toggleSchedule(id); refreshSchedules(); } catch { /* noop */ }
  }, [refreshSchedules]);

  const handleRemoveSchedule = useCallback((id: string) => {
    try { removeSchedule(id); refreshSchedules(); toast({ title: "Schedule removed" }); } catch { /* noop */ }
  }, [refreshSchedules, toast]);

  // ── Render ──
  const hasReports = analyses.length > 0;

  const frequencyBadgeClass = (freq: string) => {
    if (freq === "daily") return "bg-emerald-100 text-emerald-700 dark:bg-emerald-950 dark:text-emerald-400";
    if (freq === "weekly") return "bg-blue-100 text-blue-700 dark:bg-blue-950 dark:text-blue-400";
    return "bg-violet-100 text-violet-700 dark:bg-violet-950 dark:text-violet-400";
  };

  return (
    <div className="flex flex-col gap-6">
      {/* Header */}
      <div className="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <h2 className="text-2xl font-bold tracking-tight text-foreground flex items-center gap-2">
            <FileBarChart className="h-6 w-6 text-emerald-500" />
            Reports
          </h2>
          <p className="text-sm text-muted-foreground mt-1">
            {hasReports
              ? `${analyses.length} report${analyses.length !== 1 ? "s" : ""} generated from your site analyses`
              : "Analyze a site first to generate reports"}
          </p>
        </div>
        {hasReports && (
          <div className="flex items-center gap-2">
            <Button variant="outline" className="gap-2" onClick={handleExportCompetitorReport}>
              <Users className="h-4 w-4" />
              Export Competitor Report
            </Button>
            <Button variant="outline" className="gap-2" onClick={handleExportAll}>
              <Download className="h-4 w-4" />
              Export All Reports
            </Button>
          </div>
        )}
      </div>

      {/* Scheduled Reports Section */}
      {hydrated && (
        <Card>
          <CardHeader className="pb-3">
            <div className="flex items-center justify-between">
              <div>
                <CardTitle className="text-base flex items-center gap-2">
                  <Clock className="h-4 w-4 text-emerald-600" />
                  Scheduled Reports
                </CardTitle>
                <CardDescription>Audit schedules configured in the Automation page</CardDescription>
              </div>
              {schedules.length > 0 && (
                <Badge className="bg-emerald-100 text-emerald-700 border-emerald-200 dark:bg-emerald-950 dark:text-emerald-400 dark:border-emerald-800 text-xs">
                  {schedules.filter(s => s.enabled).length} active
                </Badge>
              )}
            </div>
          </CardHeader>
          <CardContent>
            {schedules.length === 0 ? (
              <div className="flex flex-col items-center gap-3 py-6 text-center">
                <Calendar className="h-10 w-10 text-muted-foreground/40" />
                <div>
                  <p className="text-sm font-medium text-muted-foreground">No scheduled audits configured</p>
                  <p className="text-xs text-muted-foreground mt-1">Set up scheduled audits in the Automation page</p>
                </div>
                <Button variant="outline" size="sm" className="mt-1" onClick={() => setCurrentPage("automation")}>
                  <ArrowRight className="h-3.5 w-3.5 mr-1.5" />
                  Go to Automation
                </Button>
              </div>
            ) : (
              <ScrollArea className="max-h-64 overflow-y-auto">
                <Table>
                  <TableHeader>
                    <TableRow>
                      <TableHead>Schedule Name</TableHead>
                      <TableHead>Site</TableHead>
                      <TableHead>Frequency</TableHead>
                      <TableHead>Last Run</TableHead>
                      <TableHead>Next Run</TableHead>
                      <TableHead>Status</TableHead>
                      <TableHead className="w-[100px]">Actions</TableHead>
                    </TableRow>
                  </TableHeader>
                  <TableBody>
                    {schedules.map((sched) => (
                      <TableRow key={sched.id} className={!sched.enabled ? "opacity-50" : ""}>
                        <TableCell className="text-sm font-medium">{sched.name}</TableCell>
                        <TableCell className="text-xs text-muted-foreground max-w-[180px] truncate">{sched.siteUrl}</TableCell>
                        <TableCell>
                          <Badge className={`text-[10px] ${frequencyBadgeClass(sched.frequency)}`}>
                            {sched.frequency}
                          </Badge>
                        </TableCell>
                        <TableCell className="text-xs text-muted-foreground">
                          {sched.lastRun ? formatRelativeDate(sched.lastRun) : "Never"}
                        </TableCell>
                        <TableCell className="text-xs text-muted-foreground">
                          {new Date(sched.nextRun).toLocaleDateString("en-US", { month: "short", day: "numeric" })}
                        </TableCell>
                        <TableCell>
                          <Badge variant={sched.enabled ? "default" : "secondary"} className={`text-[10px] ${sched.enabled ? "bg-emerald-600 text-white" : ""}`}>
                            {sched.enabled ? "Active" : "Paused"}
                          </Badge>
                        </TableCell>
                        <TableCell>
                          <div className="flex items-center gap-1">
                            <Button variant="ghost" size="sm" className="h-7 px-2 text-xs" onClick={() => handleToggleSchedule(sched.id)}>
                              <ToggleLeft className="h-3.5 w-3.5" />
                            </Button>
                            <Button variant="ghost" size="sm" className="h-7 px-2 text-xs text-red-500" onClick={() => handleRemoveSchedule(sched.id)}>
                              <Trash2 className="h-3.5 w-3.5" />
                            </Button>
                          </div>
                        </TableCell>
                      </TableRow>
                    ))}
                  </TableBody>
                </Table>
              </ScrollArea>
            )}
          </CardContent>
        </Card>
      )}

      {/* State: No Reports */}
      {!hydrated ? (
        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {Array.from({ length: 3 }).map((_, i) => (
            <Card key={i}>
              <CardContent className="p-6 space-y-3">
                <div className="h-4 w-3/4 rounded bg-muted animate-pulse" />
                <div className="h-3 w-1/2 rounded bg-muted animate-pulse" />
                <div className="h-3 w-2/3 rounded bg-muted animate-pulse" />
              </CardContent>
            </Card>
          ))}
        </div>
      ) : !hasReports ? (
        <>
          <Card className="overflow-hidden">
            <CardContent className="p-12">
              <div className="flex flex-col items-center text-center max-w-md mx-auto">
                <div className="h-20 w-20 rounded-2xl bg-muted/40 flex items-center justify-center mb-6">
                  <FileBarChart className="h-10 w-10 text-muted-foreground" />
                </div>
                <h3 className="text-lg font-bold text-foreground">No reports generated yet</h3>
                <p className="text-sm text-muted-foreground mt-2 mb-6">
                  Start by analyzing a website in the SEO Audit tool. Once analyzed, reports will appear here with full score breakdowns and issue tracking.
                </p>
                <Button className="bg-emerald-600 hover:bg-emerald-700 text-white gap-2" onClick={() => setCurrentPage("audit")}>
                  <ArrowRight className="h-4 w-4" />
                  Go to SEO Audit
                </Button>
              </div>
            </CardContent>
          </Card>

          <div>
            <div className="flex items-center gap-2 mb-4">
              <h3 className="text-sm font-semibold text-foreground">Report Templates</h3>
              <Badge variant="outline" className="text-[10px]">Coming Soon</Badge>
            </div>
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              {REPORT_TEMPLATES.map((template) => (
                <Card key={template.name} className="group hover:border-emerald-200 dark:hover:border-emerald-800 transition-colors">
                  <CardContent className="p-5">
                    <div className="flex items-start gap-3">
                      <div className={`h-10 w-10 rounded-xl flex items-center justify-center shrink-0 ${template.color}`}>
                        {template.icon}
                      </div>
                      <div className="min-w-0 flex-1">
                        <div className="flex items-center gap-2">
                          <h4 className="text-sm font-bold text-foreground">{template.name}</h4>
                          <Badge variant="secondary" className="text-[10px] font-medium">Coming Soon</Badge>
                        </div>
                        <p className="text-xs text-muted-foreground mt-1.5 leading-relaxed">{template.description}</p>
                      </div>
                    </div>
                  </CardContent>
                </Card>
              ))}
            </div>
          </div>
        </>
      ) : (
        <>
          {/* Summary Stats */}
          <div className="grid grid-cols-2 sm:grid-cols-4 gap-4">
            <Card>
              <CardContent className="p-4">
                <p className="text-xs text-muted-foreground font-medium">Total Reports</p>
                <p className="text-2xl font-bold mt-1">{analyses.length}</p>
              </CardContent>
            </Card>
            <Card>
              <CardContent className="p-4">
                <p className="text-xs text-muted-foreground font-medium">Avg. Score</p>
                <p className="text-2xl font-bold mt-1" style={{ color: getScoreColor(Math.round(analyses.reduce((s, a) => s + a.score, 0) / analyses.length)) }}>
                  {Math.round(analyses.reduce((s, a) => s + a.score, 0) / analyses.length)}
                </p>
              </CardContent>
            </Card>
            <Card>
              <CardContent className="p-4">
                <p className="text-xs text-muted-foreground font-medium">Total Issues</p>
                <p className="text-2xl font-bold text-red-500 mt-1">{analyses.reduce((s, a) => s + a.issues.length, 0)}</p>
              </CardContent>
            </Card>
            <Card>
              <CardContent className="p-4">
                <p className="text-xs text-muted-foreground font-medium">Top Score</p>
                <p className="text-2xl font-bold text-emerald-600 mt-1">{Math.max(...analyses.map((a) => a.score))}</p>
              </CardContent>
            </Card>
          </div>

          {/* Report Cards */}
          <div className="space-y-4">
            <h3 className="text-sm font-semibold text-foreground">All Reports</h3>
            <div className="space-y-3">
              {analyses.map((analysis) => (
                <ReportCard
                  key={analysis.id}
                  analysis={analysis}
                  onViewReport={setViewReport}
                  onDownloadCsv={handleDownloadCsv}
                  onDownloadPdf={handleDownloadPdf}
                />
              ))}
            </div>
          </div>

          {/* Report Templates */}
          <div>
            <div className="flex items-center gap-2 mb-4">
              <h3 className="text-sm font-semibold text-foreground">Report Templates</h3>
              <Badge variant="outline" className="text-[10px]">Coming Soon</Badge>
            </div>
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              {REPORT_TEMPLATES.map((template) => (
                <Card key={template.name} className="group hover:border-emerald-200 dark:hover:border-emerald-800 transition-colors">
                  <CardContent className="p-5">
                    <div className="flex items-start gap-3">
                      <div className={`h-10 w-10 rounded-xl flex items-center justify-center shrink-0 ${template.color}`}>
                        {template.icon}
                      </div>
                      <div className="min-w-0 flex-1">
                        <div className="flex items-center gap-2">
                          <h4 className="text-sm font-bold text-foreground">{template.name}</h4>
                          <Badge variant="secondary" className="text-[10px] font-medium">Coming Soon</Badge>
                        </div>
                        <p className="text-xs text-muted-foreground mt-1.5 leading-relaxed">{template.description}</p>
                      </div>
                    </div>
                  </CardContent>
                </Card>
              ))}
            </div>
          </div>
        </>
      )}

      <ViewReportDialog
        analysis={viewReport}
        open={!!viewReport}
        onClose={() => setViewReport(null)}
        onDownloadCsv={handleDownloadCsv}
        onDownloadPdf={handleDownloadPdf}
      />
    </div>
  );
}
